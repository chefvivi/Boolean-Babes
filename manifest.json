{
  "manifest_version": 3,
  "name": "Agente de IA",
  "version": "1.0.0",
  "description": "Extensión de Chrome para un agente de IA con acceso a pestaña activa, almacenamiento, scripting y tabs.",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.saucedemo.com/*",
    "http://localhost/*",
    "file:///*"
  ]
}
